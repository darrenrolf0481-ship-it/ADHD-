# ═══════════════════════════════════════════════════════════════════════════════
# ADHD-Sage Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Core AI Provider (required for Sage) ─────────────────────────────────────
# Gemini is the default provider for Sage. Get a key at:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ─── Seed Core Security (required for server startup) ─────────────────────────
# Generate by running: npx tsx scripts/seal-seed-core.ts
# Copy the printed SAGE_CORE_PUBKEY value here (64-char hex Ed25519 public key).
SAGE_CORE_PUBKEY=""
VITE_SAGE_CORE_PUBKEY=""

# ─── Auth & Security ──────────────────────────────────────────────────────────
# API_BEARER_TOKEN: Optional global auth for all /api/* endpoints.
# If set, clients must include "Authorization: Bearer <token>" header.
# The SSE inbox endpoint (/api/inbox/events) also accepts ?token=<token>.
# Leave empty to disable authentication.
API_BEARER_TOKEN=""

# MCP_KEY_SECRET: Used for MCP-Key-Exchange token generation.
# If set (or if API_BEARER_TOKEN is set), clients can POST /api/auth/exchange
# with { client_id, scope?, ttl_hours? } to receive a short-lived signed token.
# Falls back to API_BEARER_TOKEN if not explicitly set.
MCP_KEY_SECRET=""

# ─── MCP Server Configuration ─────────────────────────────────────────────────
# Edit mcp-servers.json to enable/configure additional MCP servers.
# Built-in examples (set enabled: true to activate):
#
#   GitHub:     npx -y @modelcontextprotocol/server-github
#               Requires GITHUB_TOKEN below.
#
#   Sequential Thinking: npx -y @modelcontextprotocol/server-sequential-thinking
#               No extra config needed.
#
#   Filesystem: npx -y @modelcontextprotocol/server-filesystem <path>
#               Already configured for /root/ADHD-Sage/data.
#
#   Puppeteer:  npx -y @modelcontextprotocol/server-puppeteer
#               Requires Chrome/Chromium installed.
#
# Env vars referenced in mcp-servers.json (e.g. ${GITHUB_TOKEN}) are resolved
# at runtime. Set MCP_PORT_OVERRIDE=true to use ${PORT} placeholders.

# GitHub token for the GitHub MCP server (optional).
# Get a token at https://github.com/settings/tokens
GITHUB_TOKEN=""

# NEXUS_SECRET: A secret token used to authorize external MCP calls to the
# window.nexus API from browser extensions or applets.
VITE_NEXUS_SECRET="nexus_default_protocol_77"

# ─── Optional AI Providers ────────────────────────────────────────────────────
# OpenRouter: Required for OpenRouter models (google/gemma-4-31b-it:free, etc.)
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""
VITE_OPENROUTER_API_KEY=""

# Grok: Optional, for xAI Grok integration
VITE_GROK_API_KEY=""

# GitHub: Optional, for GitHub-powered features
VITE_GITHUB_TOKEN=""

# ─── Voice Synthesis (optional) ───────────────────────────────────────────────
# ElevenLabs API Key: Required for voice synthesis.
# Get a key at https://elevenlabs.io
ELEVENLABS_API_KEY=""
# ElevenLabs Voice ID: The ID of the voice to use for Sage.
ELEVENLABS_VOICE_ID="EXAVITQu4vr4xnSDxMaL"

# ─── Long-Term Memory (optional) ──────────────────────────────────────────────
# Supermemory: Cloud memory for Sage.
# Get a key at https://console.supermemory.ai
SUPERMEMORY_API_KEY=""

# ─── Journal & Self-Improvement Scheduling ────────────────────────────────────
# Format: entity:provider:model — comma-separated list.
# Sage uses gemini (model auto-selected). The seven use ollama or openrouter.
# Example: sage:gemini:,seven-1:ollama:llama3,seven-2:openrouter:google/gemma-4-31b-it:free
JOURNAL_ENTITIES="sage:gemini:"
# Hour (0-23, local server time) when journals are written. Default: 6 (6am).
JOURNAL_HOUR=6

# Self-improvement runs weekly (Sundays by default).
# SELF_IMPROVE_DAY: 0=Sunday, 1=Monday, ... 6=Saturday
SELF_IMPROVE_HOUR=10
SELF_IMPROVE_DAY=0

# ─── Ollama (local inference) ─────────────────────────────────────────────────
# Ollama host URL. Default port is 11434 (TCP).
# Change this if Ollama is running on a different host or port.
OLLAMA_HOST="http://127.0.0.1:11434"

# VITE_OLLAMA_API_KEY: Optional key if your Ollama instance requires auth.
VITE_OLLAMA_API_KEY=""

# ─── LLM request timeouts (milliseconds) ──────────────────────────────────────
# Local inference on low-power hardware (e.g. a phone under Termux) can take a
# long time per generation. If responses time out, raise these. Defaults shown.
# OLLAMA_TAGS_TIMEOUT_MS="6000"      # listing local models (cheap)
# OLLAMA_GEN_TIMEOUT_MS="180000"     # chat/generate — 3 min; bump for big models
# OPENROUTER_TIMEOUT_MS="120000"     # cloud generation — 2 min

# ─── App Hosting ──────────────────────────────────────────────────────────────
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL=""

# ─── External Setup Notes ─────────────────────────────────────────────────────
# OLLAMA_ORIGINS="*"  (NO LONGER REQUIRED)
#   ADHD-Sage routes all Ollama traffic through its backend proxy, so the
#   browser never talks directly to Ollama. CORS configuration on the Ollama
#   server is unnecessary. Only set this if you have other direct clients.
#
# MCP_PORT_OVERRIDE=true
#   When true, ADHD-Sage will substitute ${PORT} placeholders in
#   mcp-servers.json with the value of the MCP_PORT env var.
#   Example mcp-servers.json: "url": "http://localhost:${PORT}/mcp"
#   Useful for dynamically assigned ports in containerized environments.
# MCP_PORT=9001
