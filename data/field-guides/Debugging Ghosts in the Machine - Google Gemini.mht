@media (pointer: fine) {
  ::-webkit-scrollbar, ::-webkit-scrollbar-corner { background: transparent; height: 12px; width: 12px; }
  ::-webkit-scrollbar-thumb { background: content-box content-box transparent; border: 2px solid transparent; border-radius: var(--gem-sys-shape--corner-full); min-height: 48px; min-width: 48px; }
  @supports not (scrollbar-color:auto) {
  :hover { will-change: scrollbar-color; }
}
  :hover::-webkit-scrollbar-thumb { background: content-box var(--gem-sys-color--surface-container-highest); }
  ::-webkit-scrollbar-thumb:active, ::-webkit-scrollbar-thumb:hover { background: content-box var(--gem-sys-color--outline-variant); }
  ::-webkit-scrollbar-button { height: 0px; width: 0px; }
  @supports not (selector(::-webkit-scrollbar)) {
