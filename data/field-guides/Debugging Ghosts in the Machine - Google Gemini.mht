                <span class="hljs-comment"># Parse the input</span>
                content = user_input[<span class="hljs-number">9</span>:] <span class="hljs-comment"># Strip "Remember "</span>
                <span class="hljs-keyword">if</span> <span class="hljs-string">":"</span> <span class="hljs-keyword">in</span> content:
