        <span class="hljs-comment"># MEMORY COMMAND: "Remember [category]: [fact]"</span>
        <span class="hljs-comment"># Example: "Remember anomaly: The kitchen gets cold at 3AM."</span>
        <span class="hljs-keyword">elif</span> user_input.lower().startswith(<span class="hljs-string">"remember"</span>):
