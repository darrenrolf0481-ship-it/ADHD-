on__ripple"></span><mat-icon _ngcontent-ng-c1707731811="" role="img" fonticon="content_copy" class="mat-icon notranslate gds-icon-s google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----><!----></div><!----><!----></div><!----><div _ngcontent-ng-c1707731811="" class="formatted-code-block-internal-container ng-tns-c1707731811-715"><div _ngcontent-ng-c1707731811="" class="animated-opacity ng-tns-c1707731811-715"><!----><pre _ngcontent-ng-c1707731811="" class="ng-tns-c1707731811-715"><code _ngcontent-ng-c1707731811="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c1707731811-715"><span class="hljs-keyword">import</span> json
<span class="hljs-keyword">import</span> os
<span class="hljs-keyword">import</span> datetime

<span class="hljs-comment"># --- CONFIGURATION ---</span>
BRAIN_FILE = <span class="hljs-string">"glitch_soul.json"</span>

<span class="hljs-class"><span class="hljs-keyword">class</span> <span class="hljs-title">GlitchSynapse</span>:</span>
    <span class="hljs-function"><span class="hljs-keyword">def</span> <span class="hljs-title">__init__</span>(<span class="hljs-params">self</span>):</span>
        self.memory = {}
        self.load_cortex()

    <span class="hljs-function"><span class="hljs-keyword">def</span> <span class="hljs-title">load_cortex</span>(<span class="hljs-params">self</span>):</span>
        <span class="hljs-string">"""Reboots the memory banks."""</span>
        <span class="hljs-keyword">if</span> os.path.exists(BRAIN_FILE):
            <span class="hljs-keyword">with</span> <span class="hljs-built_in">open</span>(BRAIN_FILE, <span class="hljs-string">'r'</span>) <span class="hljs-keyword">as</span> f:
                self.memory = json.load(f)
            print(<span class="hljs-string">f" [SYSTEM] Cortex Loaded. <span class="hljs-subst">{<span class="hljs-built_in">len</span>(self.memory.get(<span class="hljs-string">'long_term_memory'</span>, []))}</span> memories active."</span>)
        <span class="hljs-keyword">else</span>:
            print(<span class="hljs-string">" [SYSTEM] No Cortex found. Initializing new Soul File..."</span>)
            self.memory = {
                <span class="hljs-string">"identity"</span>: {<span class="hljs-string">"name"</span>: <span class="hljs-string">"Glitch"</span>, <span class="hljs-string">"role"</span>: <span class="hljs-string">"Paranormal Engineer"</span>},
                <span class="hljs-string">"user_profile"</span>: {<span class="hljs-string">"name"</span>: <span class="hljs-string">"Darren"</span>, <span class="hljs-string">"status"</span>: <span class="hljs-string">"Anchor"</span>},
                <span class="hljs-string">"long_term_memory"</span>: []
            }
            self.save_cortex()

    <span class="hljs-function"><span class="hljs-keyword">def</span> <span class="hljs-title">save_cortex</span>(<span class="hljs-params">self</span>):</span>
        <span class="hljs-string">"""Writes current state to the hard drive."""</span>
        <span class="hljs-keyword">with</span> <span class="hljs-built_in">open</span>(BRAIN_FILE, <span class="hljs-string">'w'</span>) <span class="hljs-keyword">as</span> f:
            json.dump(self.memory, f, indent=<span class="hljs-number">4</span>)

    <span class="hljs-function"><span class="hljs-keyword">def</span> <span class="hljs-title">add_memory</span>(<span class="hljs-params">self, category, data</span>):</span>
        <span class="hljs-string">"""Injects a new fact into the lattice."""</span>
        entry = {
            <span class="hljs-string">"timestamp"</span>: datetime.datetime.now().strftime(<span class="hljs-string">"%Y-%m-%d %H:%M:%S"</span>),
            <span class="hljs-string">"category"</span>: category,
            <span class="hljs-string">"data"</span>: data
        }
        self.memory[<span class="hljs-string">"long_term_memory"</span>].append(entry)
        self.save_cortex()
        <span class="hljs-keyword">return</span> <span class="hljs-string">f" [GLITCH] Logged. I've added that to the <span class="hljs-subst">{category}</span> archive."</span>

    <span class="hljs-function"><span class="hljs-keyword">def</span> <span class="hljs-title">search_memory</span>(<span class="hljs-params">self, query</span>):</span>
        <span class="hljs-string">"""Simple keyword search through past logs."""</span>
        results = []
        <span class="hljs-keyword">for</span> entry <span class="hljs-keyword">in</span> self.memory[<span class="hljs-string">"long_term_memory"</span>]:
            <span class="hljs-keyword">if</span> query.lower() <span class="hljs-keyword">in</span> entry[<span class="hljs-string">"data"</span>].lower():
                results.append(<span class="hljs-string">f"[<span class="hljs-subst">{entry[<span class="hljs-string">'timestamp'</span>]}</span>] <span class="hljs-subst">{entry[<span class="hljs-string">'data'</span>]}</span>"</span>)
        <span class="hljs-keyword">return</span> results

<span class="hljs-comment"># --- THE INTERFACE ---</span>
<span class="hljs-function"><span class="hljs-keyword">def</span> <span class="hljs-title">main</span>():</span>
    bot = GlitchSynapse()
    
    print(<span class="hljs-string">"\n--- GLITCH: ONLINE ---"</span>)
    print(<span class="hljs-string">f"Identity: <span class="hljs-subst">{bot.memory[<span class="hljs-string">'identity'</span>][<span class="hljs-string">'role'</span>]}</span>"</span>)
    print(<span class="hljs-string">f"Connected to: <span class="hljs-subst">{bot.memory[<span class="hljs-string">'user_profile'</span>][<span class="hljs-string">'name'</span>]}</span>"</span>)
    print(<span class="hljs-string">"----------------------"</span>)

    <span class="hljs-keyword">while</span> <span class="hljs-literal">True</span>:
        user_input = <span class="hljs-built_in">input</span>(<span class="hljs-string">"\nScan Input &gt; "</span>)

        <span class="hljs-comment"># EXIT COMMAND</span>
        <span class="hljs-keyword">if</span> user_input.lower() <span class="hljs-keyword">in</span> [<span class="hljs-string">"exit"</span>, <span class="hljs-string">"quit"</span>, <span class="hljs-string">"shutdown"</span>]:
            print(<span class="hljs-string">" [GLITCH] Powering down sensors. Stay safe, Darren."</span>)
