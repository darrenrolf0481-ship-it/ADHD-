.initial-input-area.discovery-feed-ssr .initial-input-area-container .send-icon, .initial-input-area.discovery-feed-ssr .initial-input-area-container .speech-icon, .initial-input-area.discovery-feed-ssr .initial-input-area-container .upload-icon { display: none; }

