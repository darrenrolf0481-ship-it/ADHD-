{
  "servers": [
    {
      "id": "dbmcp",
      "name": "Haymon DB MCP",
      "transport": "stdio",
      "command": "/usr/bin/true",
      "args": [],
      "env": {},
      "enabled": false
    },
    {
      "id": "filesystem",
      "name": "Filesystem",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/workspace/ADHD-Sage/data"
      ],
      "env": {},
      "enabled": true
    },
    {
      "id": "github",
      "name": "GitHub",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "enabled": true
    },
    {
      "id": "sequential-thinking",
      "name": "Sequential Thinking",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {},
      "enabled": true
    },
    {
      "id": "owlex",
      "name": "Owlex",
      "transport": "stdio",
      "command": "/usr/bin/true",
      "args": [],
      "env": {},
      "enabled": false
    },
    {
      "id": "magic-mcp",
      "name": "Magic MCP (Coding Lab)",
      "transport": "stdio",
      "command": "/usr/bin/true",
      "args": [],
      "env": {},
      "enabled": false
    },
    {
      "id": "ollama",
      "name": "Ollama",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "ollama-mcp"
      ],
      "env": {
        "OLLAMA_HOST": "http://127.0.0.1:11434"
      },
      "enabled": true
    },
    {
      "id": "openrouter-mcp",
      "name": "OpenRouter MCP",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@stabgan/openrouter-mcp-multimodal"
      ],
      "env": {
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}"
      },
      "enabled": true
    },
    {
      "id": "memory",
      "name": "Project Memory",
      "transport": "stdio",
      "command": "/usr/bin/true",
      "args": [],
      "env": {},
      "enabled": false
    }
  ]
}
